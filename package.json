{
	"name": "@panoscool/fetch-client",
	"version": "0.1.0",
	"license": "MIT",
	"description": "A tiny, typed HTTP client for the fetch API — interceptors, JSON handling, and structured errors.",
	"funding": "https://github.com/sponsors/panoscool",
	"homepage": "https://github.com/panoscool/fetch-client#readme",
	"author": {
		"name": "Panos Kullolli",
		"email": "lkullolli@gmail.com",
		"url": "https://panoscool.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/panoscool/fetch-client.git"
	},
	"bugs": {
		"url": "https://github.com/panoscool/fetch-client/issues"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"scripts": {
		"test": "bun test",
		"build": "bun build.ts",
		"prepublishOnly": "npm run build",
		"release": "bash ./scripts/release.sh",
		"lint": "biome check",
		"format": "biome format --write"
	},
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"fetch",
		"http",
		"http-client",
		"client",
		"rest",
		"api",
		"request",
		"axios",
		"interceptors",
		"typescript",
		"esm",
		"cjs"
	],
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "1.3.5",
		"typescript": "5.9.3"
	}
}
